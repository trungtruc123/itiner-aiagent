# Environment
ENVIRONMENT=development

# API
APP_NAME=TravelPlannerAI
APP_VERSION=1.0.0
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=postgresql+asyncpg://postgres:your-password@localhost:5432/travel_planner
DATABASE_SYNC_URL=postgresql://postgres:your-password@localhost:5432/travel_planner

# Redis
REDIS_URL=redis://localhost:6379/0

# Neo4j
NEO4J_URI=neo4j+s://your-neo4j-host.databases.neo4j.io
NEO4J_USER=your-neo4j-user
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=your-neo4j-database

# LLM
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# Langfuse
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key
LANGFUSE_SECRET_KEY=your-langfuse-secret-key
LANGFUSE_HOST=https://us.cloud.langfuse.com

# Mem0
MEM0_COLLECTION_NAME=travel_planner_memory

# Weather API
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_URL=https://api.openweathermap.org/data/2.5

# Rate Limiting
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_CHAT=30/minute

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
